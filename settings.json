{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/pretask_flag.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash|Edit|Write|MultiEdit|NotebookEdit|mcp__plugin_serena_serena__execute_shell_command|mcp__plugin_serena_serena__replace_content|mcp__plugin_serena_serena__replace_symbol_body|mcp__plugin_serena_serena__insert_after_symbol|mcp__plugin_serena_serena__insert_before_symbol|mcp__plugin_serena_serena__rename_symbol|mcp__plugin_serena_serena__delete_lines|mcp__plugin_serena_serena__create_text_file|mcp__plugin_serena_serena__edit_memory|mcp__plugin_serena_serena__delete_memory|mcp__plugin_serena_serena__insert_at_line|mcp__plugin_serena_serena__replace_lines",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/enforce_delegation.py",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/agent_stop.py",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "rm -f .claude/.in_subtask.flag",
            "timeout": 2
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "serena@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high"
}
